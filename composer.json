{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "alanaktion/mytube",
    "type": "project",
    "description": "A self-hostable video archive web app",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "abraham/twitteroauth": "^7.1",
        "google/apiclient": "^2.19",
        "guzzlehttp/guzzle": "^7.10",
        "intervention/image": "^3.11.7",
        "laravel-lang/lang": "^15.28.5",
        "laravel/framework": "^12.54.1",
        "laravel/sanctum": "^4.3.1",
        "laravel/scout": "^10.25",
        "laravel/telescope": "^5.18",
        "laravel/tinker": "^2.11.1",
        "laravel/ui": "^4.6.2",
        "meilisearch/meilisearch-php": "^1.16.1",
        "nicklaw5/twitch-api-php": "^7.2",
        "norkunas/youtube-dl-php": "^2.13",
        "opcodesio/log-viewer": "^3.23",
        "predis/predis": "^2.4.1",
        "rebing/graphql-laravel": "^9.16"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.3",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.28",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "phpunit/phpunit": "^11.5.55",
        "rector/rector": "^2.3.8",
        "spatie/laravel-ignition": "^2.11"
    },
    "autoload": {
        "files": [
            "app/helpers.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "Google_Task_Composer::cleanup",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "google/apiclient-services": [
            "YouTube"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.3.17"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
